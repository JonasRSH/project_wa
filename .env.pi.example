# Domain/Subdomain, unter der die App erreichbar ist (z. B. wa-test.deine-domain.de)
DOMAIN=wa-test.example.com

# Django-Konfiguration
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-for-production
DJANGO_ALLOWED_HOSTS=wa-test.example.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://wa-test.example.com